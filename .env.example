# OpenClaw / Ollama
OLLAMA_MODEL=qwen2.5:0.5b
CONTEXT_WINDOW=4096
OLLAMA_CONTEXT_LENGTH=4096
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
LOCAL_PRIMARY=0
OLLAMA_SYNC_FALLBACK=0
FALLBACK_GUARD=1
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL_SEC=3600
REDIS_CACHE_PREFIX=openclaw:prompt-cache

# Optional cloud fallback #1 (OpenClaw provider ID/API/base URL/model)
# Example for OpenRouter (OpenAI-compatible):
# ALT1_PROVIDER_ID=openrouter
# ALT1_PROVIDER_API=openai
# ALT1_BASE_URL=https://openrouter.ai/api/v1
# ALT1_API_KEY=...
# ALT1_MODEL=meta-llama/llama-3.1-8b-instruct:free
ALT1_PROVIDER_ID=
ALT1_PROVIDER_API=
ALT1_BASE_URL=
ALT1_API_KEY=
ALT1_MODEL=

# Optional cloud fallback #2
ALT2_PROVIDER_ID=
ALT2_PROVIDER_API=
ALT2_BASE_URL=
ALT2_API_KEY=
ALT2_MODEL=
MAX_AGENT_STEPS=5

# OpenClaw native Discord channel
DISCORD_BOT_TOKEN=

# SearXNG (local search API)
SEARXNG_BASE_URL=http://localhost/
SEARXNG_INSTANCE_NAME=homelabs-searxng
