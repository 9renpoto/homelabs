{
  "models": {
    "providers": {
      "google": {
        "api": "google-generative-ai",
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "models": []
      },
      "ollama": {
        "api": "ollama",
        "baseUrl": "http://ollama:11434",
        "apiKey": "ollama-local"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash-lite",
        "fallbacks": [
          "ollama/qwen2.5:3b-instruct-q4_K_M"
        ]
      },
      "bootstrapMaxChars": 1024,
      "bootstrapTotalMaxChars": 4096,
      "maxConcurrent": 1,
      "subagents": {
        "maxConcurrent": 1
      }
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "groupPolicy": "allowlist",
      "streaming": "off",
      "allowBots": false,
      "dmPolicy": "disabled",
      "guilds": {
        "*": {
          "requireMention": false
        }
      }
    }
  }
}
