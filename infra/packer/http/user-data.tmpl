#cloud-config
# Ubuntu autoinstall user-data for openclaw-k3s Packer build.
# build.ps1 replaces __SSH_PUBLIC_KEY__ before calling packer build.

autoinstall:
  version: 1

  locale: en_US.UTF-8
  keyboard:
    layout: us

  refresh-installer:
    update: false

  identity:
    hostname: openclaw-k3s
    username: openclaw
    # Temporary build password (SHA-512 of "packer").
    # SSH password authentication is disabled; this enables console access only.
    password: "$6$SIdVVV0yHcjIOIWf$L2a7nbBSZYgPvZ4zBJ0KqJUA/1AreH8AsKc3MhgFZaAhV6JRbL3UGBmgwyVTq.6EsvVDMcM0Ffj39IFftQmvQ/"

  ssh:
    install-server: true
    authorized-keys:
      - __SSH_PUBLIC_KEY__
    allow-pw: false

  storage:
    layout:
      name: lvm
      sizing-policy: scaled

  packages:
    - curl
    - git
    - qemu-guest-agent
    - ufw

  user-data:
    write_files:
      - path: /etc/sysctl.d/99-k3s.conf
        permissions: "0644"
        content: |
          vm.max_map_count=262144

  late-commands:
    - systemctl enable qemu-guest-agent || true
    - sysctl --system
    - ufw default deny incoming
    - ufw default allow outgoing
    - ufw allow OpenSSH
    - ufw --force enable
