vm_name              = "openclaw-k3s"
iso_url              = "https://releases.ubuntu.com/24.04.2/ubuntu-24.04.2-live-server-amd64.iso"
iso_checksum         = "sha256:REPLACE_WITH_UBUNTU_ISO_CHECKSUM"
output_directory     = "output-openclaw-k3s"
cpus                 = 8
memory               = 32768
disk_size_mb         = 131072
enable_nested_virtualization = false
ssh_username         = "ubuntu"
ssh_private_key_file = "/absolute/path/to/id_ed25519"

# GPU passthrough (optional)
# 1. Find the PCI ID on the Windows host (PowerShell, run as admin):
#    Get-PnpDevice -Class Display | Where-Object { $_.InstanceId -match 'VEN_10DE' } |
#      Get-PnpDeviceProperty -KeyName DEVPKEY_Device_LocationInfo | Select Data
# 2. Ensure the host uses iGPU for display so the NVIDIA GPU is free.
# enable_gpu_passthrough = true
# gpu_pci_id             = "0000:03:00.0"
